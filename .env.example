# ====== UBOBO — Environment variables ======

# --- Database ---
# Dev (SQLite): no setup needed, file is created automatically
DATABASE_URL="file:./prisma/dev.db"
# Prod (Postgres): set DATABASE_URL on hosting provider, e.g. Neon/Supabase/Railway
# DATABASE_URL="postgresql://user:pass@host:5432/ubobo?schema=public"

# --- Server ---
# API_PORT is intentionally separate from PORT to avoid collisions with the
# Vite dev server (which auto-reads PORT). In production the backend uses
# PORT when API_PORT is unset.
API_PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# --- Auth (single-admin) ---
JWT_SECRET="change-me-in-production-please-use-a-strong-secret-of-at-least-32-chars"
ADMIN_EMAIL="admin@ubobo.fr"
ADMIN_PASSWORD="admin123"
# On first server boot, the admin user is created/updated with these credentials.

# --- Stripe (test mode by default) ---
# Create keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# --- Frontend (Vite reads VITE_*) ---
VITE_API_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
