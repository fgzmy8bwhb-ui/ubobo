# ====== UBOBO — Environment variables ======

# --- Database ---
# Dev (SQLite): no setup needed, file is created automatically
DATABASE_URL="file:./prisma/dev.db"
# Prod (Postgres): set DATABASE_URL on hosting provider, e.g. Neon/Supabase/Railway
# DATABASE_URL="postgresql://user:pass@host:5432/ubobo?schema=public"

# --- Server ---
# API_PORT is intentionally separate from PORT to avoid collisions with the
# Vite dev server (which auto-reads PORT). In production the backend uses
# PORT when API_PORT is unset.
API_PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# --- Auth (single-admin) ---
JWT_SECRET="change-me-in-production-please-use-a-strong-secret-of-at-least-32-chars"
ADMIN_EMAIL="admin@ubobo.fr"
ADMIN_PASSWORD="admin123"
# On first server boot, the admin user is created/updated with these credentials.

# --- Stripe (test mode by default) ---
# Create keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# --- Cloudflare R2 ---
CF_ACCOUNT_ID="your_account_id"
CF_R2_ACCESS_KEY_ID="your_access_key_id"
CF_R2_SECRET_ACCESS_KEY="your_secret_access_key"
CF_R2_BUCKET="ubobo-images"
CF_R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev"

# --- Twilio SMS (admin notified by SMS on each new order) ---
# Create an account at https://console.twilio.com, buy a phone number capable
# of sending SMS to your country, then set:
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_FROM_NUMBER="+1xxxxxxxxxx" # the Twilio number you bought
ADMIN_NOTIFY_PHONE="+33612345678" # your own phone, E.164 format, receives the SMS

# --- Frontend (Vite reads VITE_*) ---
VITE_API_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
