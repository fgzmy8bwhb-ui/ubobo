# Copie ce fichier en .env.production et remplis les vraies valeurs
# Ne commite JAMAIS .env.production

DATABASE_PROVIDER="postgresql"
DATABASE_URL="postgresql://user:password@host.neon.tech/ubobo?sslmode=require"

API_PORT=4000
NODE_ENV=production
CLIENT_ORIGIN=https://ubobo.vercel.app

JWT_SECRET="remplace-par-une-cle-aleatoire-de-64-chars-minimum"
ADMIN_EMAIL="admin@ubobo.fr"
ADMIN_PASSWORD="remplace-par-un-vrai-mot-de-passe"

STRIPE_SECRET_KEY="sk_live_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# Ces vars VITE_* ne servent pas côté Railway (backend uniquement)
# Elles sont à configurer dans Vercel
VITE_API_URL=https://ubobo-api.railway.app
VITE_SOCKET_URL=https://ubobo-api.railway.app
VITE_STRIPE_PUBLISHABLE_KEY="pk_live_xxx"
